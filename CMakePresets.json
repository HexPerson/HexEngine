{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2022-x64-debug",
      "displayName": "VS2022 x64 Debug",
      "description": "Canonical HexEngine orchestration preset (legacy compile remains .sln/.vcxproj).",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release",
        "HEXENGINE_DEPENDENCY_BACKEND": "vcpkg_manifest"
      }
    },
    {
      "name": "vs2022-x64-release",
      "displayName": "VS2022 x64 Release",
      "description": "Canonical HexEngine orchestration preset (legacy compile remains .sln/.vcxproj).",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release",
        "HEXENGINE_DEPENDENCY_BACKEND": "vcpkg_manifest"
      }
    },
    {
      "name": "vs2022-x64-debug-vcpkg",
      "displayName": "VS2022 x64 Debug (vcpkg toolchain)",
      "description": "Canonical preset with vcpkg manifest toolchain enabled.",
      "inherits": "vs2022-x64-debug",
      "condition": {
        "type": "notEquals",
        "lhs": "$env{VCPKG_ROOT}",
        "rhs": ""
      },
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_FEATURE_FLAGS": "manifests"
      }
    },
    {
      "name": "vs2022-x64-release-vcpkg",
      "displayName": "VS2022 x64 Release (vcpkg toolchain)",
      "description": "Canonical preset with vcpkg manifest toolchain enabled.",
      "inherits": "vs2022-x64-release",
      "condition": {
        "type": "notEquals",
        "lhs": "$env{VCPKG_ROOT}",
        "rhs": ""
      },
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_FEATURE_FLAGS": "manifests"
      }
    },
    {
      "name": "vs2022-x64-debug-dep-probe",
      "displayName": "VS2022 x64 Debug + Dep Probe",
      "description": "Enables the Phase 3 dependency probe executable.",
      "inherits": "vs2022-x64-debug",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "HEXENGINE_ENABLE_DEP_PROBE": "ON"
      }
    },
    {
      "name": "vs2022-x64-debug-assimp-probe",
      "displayName": "VS2022 x64 Debug + Assimp Probe",
      "description": "Enables legacy imported-target assimp probe executable.",
      "inherits": "vs2022-x64-debug",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "HEXENGINE_ENABLE_LEGACY_ASSIMP_PROBE": "ON"
      }
    },
    {
      "name": "vs2022-x64-debug-brotli-probe",
      "displayName": "VS2022 x64 Debug + Brotli Probe",
      "description": "Enables legacy imported-target brotli probe executable.",
      "inherits": "vs2022-x64-debug",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "HEXENGINE_ENABLE_LEGACY_BROTLI_PROBE": "ON"
      }
    },
    {
      "name": "vs2022-x64-debug-streamline-probe",
      "displayName": "VS2022 x64 Debug + Streamline Probe",
      "description": "Enables Streamline imported-target probe executable.",
      "inherits": "vs2022-x64-debug",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "HEXENGINE_ENABLE_STREAMLINE_PROBE": "ON"
      }
    },
    {
      "name": "vs2022-x64-debug-shaderconductor-probe",
      "displayName": "VS2022 x64 Debug + ShaderConductor Probe",
      "description": "Enables ShaderConductor imported-target probe executable.",
      "inherits": "vs2022-x64-debug",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "HEXENGINE_ENABLE_SHADERCONDUCTOR_PROBE": "ON"
      }
    },
    {
      "name": "vs2022-x64-debug-physx-probe",
      "displayName": "VS2022 x64 Debug + PhysX Probe",
      "description": "Enables PhysX imported-target probe executable.",
      "inherits": "vs2022-x64-debug",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "HEXENGINE_ENABLE_PHYSX_PROBE": "ON"
      }
    },
    {
      "name": "vs2022-x64-debug-required-runtime-probes",
      "displayName": "VS2022 x64 Debug + Required Runtime Probes",
      "description": "Enables PhysX, ShaderConductor, and Streamline probe executables.",
