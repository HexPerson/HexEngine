{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2022-x64-debug",
      "displayName": "VS2022 x64 Debug",
      "description": "Canonical HexEngine orchestration preset (legacy compile remains .sln/.vcxproj).",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release"
      }
    },
    {
      "name": "vs2022-x64-release",
      "displayName": "VS2022 x64 Release",
      "description": "Canonical HexEngine orchestration preset (legacy compile remains .sln/.vcxproj).",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release"
      }
    },
    {
      "name": "vs2022-x64-debug-dep-probe",
      "displayName": "VS2022 x64 Debug + Dep Probe",
      "description": "Enables the Phase 3 dependency probe executable.",
      "inherits": "vs2022-x64-debug",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "HEXENGINE_ENABLE_DEP_PROBE": "ON"
      }
    },
    {
      "name": "vs2022-x64-debug-assimp-probe",
      "displayName": "VS2022 x64 Debug + Assimp Probe",
      "description": "Enables legacy imported-target assimp probe executable.",
      "inherits": "vs2022-x64-debug",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "HEXENGINE_ENABLE_LEGACY_ASSIMP_PROBE": "ON"
      }
    },
    {
      "name": "vs2022-x64-debug-brotli-probe",
      "displayName": "VS2022 x64 Debug + Brotli Probe",
      "description": "Enables legacy imported-target brotli probe executable.",
      "inherits": "vs2022-x64-debug",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "HEXENGINE_ENABLE_LEGACY_BROTLI_PROBE": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "deps-plan-debug",
      "displayName": "Dependency Plan (Debug preset)",
      "configurePreset": "vs2022-x64-debug",
      "targets": [
        "hex-deps-plan"
      ]
    },
    {
      "name": "deps-plan-release",
      "displayName": "Dependency Plan (Release preset)",
      "configurePreset": "vs2022-x64-release",
      "targets": [
        "hex-deps-plan"
      ]
    },
    {
      "name": "deps-check-refs-debug",
      "displayName": "Dependency Ref Check (Debug preset)",
      "configurePreset": "vs2022-x64-debug",
      "targets": [
        "hex-deps-check-refs"
      ]
    },
    {
      "name": "deps-lock-refs-debug",
      "displayName": "Dependency Ref Lock (Debug preset)",
      "configurePreset": "vs2022-x64-debug",
      "targets": [
        "hex-deps-lock-refs"
      ]
    },
    {
      "name": "headeronly-bootstrap-debug",
      "displayName": "Header-Only Bootstrap (Debug preset)",
      "configurePreset": "vs2022-x64-debug",
      "targets": [
        "hex-headeronly-bootstrap"
      ]
    },
    {
      "name": "dep-probe-debug",
      "displayName": "Dependency Probe Build",
      "configurePreset": "vs2022-x64-debug-dep-probe",
      "targets": [
        "hex-dep-probe"
      ],
      "configuration": "Debug"
    },
    {
      "name": "assimp-probe-debug",
      "displayName": "Assimp Imported Target Probe Build",
      "configurePreset": "vs2022-x64-debug-assimp-probe",
      "targets": [
        "hex-assimp-probe"
      ],
      "configuration": "Debug"
    },
    {
      "name": "brotli-probe-debug",
      "displayName": "Brotli Imported Target Probe Build",
      "configurePreset": "vs2022-x64-debug-brotli-probe",
      "targets": [
        "hex-brotli-probe"
      ],
      "configuration": "Debug"
    },
    {
      "name": "legacy-setup-debug",
      "displayName": "Legacy Setup (Debug preset)",
      "configurePreset": "vs2022-x64-debug",
      "targets": [
        "hex-legacy-setup"
      ]
    }
  ]
}
