      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "HEXENGINE_ENABLE_PHYSX_PROBE": "ON",
        "HEXENGINE_ENABLE_SHADERCONDUCTOR_PROBE": "ON",
        "HEXENGINE_ENABLE_STREAMLINE_PROBE": "ON"
      }
    }
  ],
