{
  "schema_version": 1,
  "description": "HexEngine third-party dependency manifest for staged migration to declarative builds.",
  "dependencies": [
    {
      "name": "assimp",
      "path": "ThirdParty/assimp",
      "git_url": "https://github.com/assimp/assimp.git",
      "ref": null,
      "build_system": "cmake+msbuild",
      "notes": "Builds static assimp and zlib artifacts via setup.py legacy flow.",
      "legacy_stage_paths": [
        "Libs/x64/<Config>/assimp-*.lib",
        "Libs/x64/<Config>/zlibstatic*.lib",
        "Include/assimp/config.h"
      ]
    },
    {
      "name": "directxtk",
      "path": "ThirdParty/directxtk",
      "git_url": "https://github.com/microsoft/DirectXTK.git",
      "ref": null,
      "build_system": "cmake+msbuild",
      "notes": "No automatic pull in default mode; use --update for floating updates.",
      "legacy_stage_paths": [
        "Libs/x64/<Config>/DirectXTK.lib",
        "Libs/x64/<Config>/DirectXTKAudioWin8.lib"
      ]
    },
    {
      "name": "nrd",
      "path": "ThirdParty/nrd",
      "git_url": "https://github.com/NVIDIAGameWorks/RayTracingDenoiser.git",
      "ref": null,
      "build_system": "cmake+msbuild",
      "notes": "Recursive clone.",
      "legacy_stage_paths": [
        "Libs/x64/<Config>/NRD.lib"
      ]
    },
    {
      "name": "physx",
      "path": "ThirdParty/physx",
      "git_url": "https://github.com/NVIDIA-Omniverse/PhysX.git",
      "ref": null,
      "build_system": "custom+msbuild",
      "notes": "Legacy flow modifies vc17 preset xml and stages libs/dlls.",
      "legacy_stage_paths": [
        "Libs/x64/<Config>/*.lib",
        "Bin/x64/<Config>/Bin/*.dll"
      ]
    },
    {
      "name": "shaderconductor",
